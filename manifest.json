{
  "manifest_version": 3,
  "name": "Lead ID Quick Opener",
  "version": "1.1",
  "description": "Open CLM lead directly from detected ID",
  "permissions": ["contextMenus", "activeTab", "scripting"],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "*://*.force.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.force.com/*"],
      "js": ["content.js"]
    }
  ]
}